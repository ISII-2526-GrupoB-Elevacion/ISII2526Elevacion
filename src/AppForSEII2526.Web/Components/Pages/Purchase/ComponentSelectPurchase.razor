@page "/purchase/select"

@using Microsoft.AspNetCore.Authorization
@using AppForSEII2526.Web.API
@inject AppForSEII2526APIClient apiclient
@inject ILogger<ComponentSelectPurchase> logger
@inject PurchaseStateContainer purchaseState
@inject NavigationManager navigation

@attribute [Authorize]

<h3>Select Cars For Purchase</h3>
<div class="container-fluid">
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @errors</p>
    </div>
    <div class="row">
        <div class="col-8">
            <div class="row">
                <div class="col" style="min-width: 300px;">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Color</span>
                        <input type="text" id="inputColor" @bind=filtroColor class="form-control" placeholder="Color" aria-label="Color" aria-describedby="basic-addon1">
                    </div>
                </div>
                <div class="col" style="min-width: 300px;">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Model</span>
                        <input type="text" id="inputModel" @bind=modelo class="form-control" placeholder="Model" aria-label="Modelo" aria-describedby="basic-addon1">
                    </div>
                </div>
                <div class="col">
                    <button type="button" class="btn btn-primary" @onclick=@SearchCars id="searchCarsButton">Search Cars</button>
                </div>
            </div>
            <div class="row">
                @if (cars == null)
                {
                    <p>Loading cars...</p>
                }
                else if (cars.Count == 0 && string.IsNullOrEmpty(filtroColor) && string.IsNullOrEmpty(modelo))
                {
                    <p><em>There are no cars available for being purchased.</em></p>
                }
                else
                {
                    <div class="mh-100 table-responsive">
                        <table class="table table-condensed table-hover" id="TableOfCars">
                            <thead>
                                <tr>
                                    <th>Model</th>
                                    <th>Color</th>
                                    <th>Fuel Type</th>
                                    <th>Manufacturer</th>
                                    <th>Purchasing Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var car in cars)
                                {
                                    <tr id="CarData_@car.Id">
                                        <td>@car.Model</td>
                                        <td>@car.Color</td>
                                        <td>@car.FuelType</td>
                                        <td>@car.Manufacturer</td>
                                        <td>@car.PurchasingPrice €</td>
                                        <td>
                                            <button class="btn btn-outline-secondary" id="carToPurchase_@car.Model" @onclick="@(() => AddCar(car))">Add</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        <div class="col-2 offset-1" hidden="@hidePurchaseCart">
            <div class="row">
                <h3>Shopping Cart</h3>
            </div>
            @foreach (PurchaseItemDTO item in purchase.PurchaseItems)
            {
                <div class="row">
                    <button type="button" class="btn btn-light" id="removeCar_@item.Model" @onclick="@(() => RemovePurchaseItem(item))">x @item.Model - @item.PurchasingPrice€</button>
                </div>
            }
            <div class="row">
                <button type="button" class="btn btn-primary" id="purchaseCarButton" @onclick=@PurchaseCars>Purchase Cars</button>
            </div>
        </div>
    </div>
</div>

@code {
    private bool hidePurchaseCart { get { return purchase.PurchaseItems.Count == 0; } }
    private ICollection<CarForPurchaseDTO> cars;
    private bool hideErrors { get { return errors.Length == 0; } }
    private string errors = "";
    private string filtroColor { get; set; }
    private string modelo { get; set; }

    private PurchaseForCreateDTO purchase => purchaseState.Purchase;

    private bool hiddenPurchaseCart = true;

    private void AddCar(CarForPurchaseDTO car)
    {
        purchaseState.AddCarToPurchase(car);
    }

    private void RemovePurchaseItem(PurchaseItemDTO item)
    {
        purchaseState.RemovePurchaseItemToPurchase(item);
        if (purchase.PurchaseItems.Count == 0) hiddenPurchaseCart = true;
    }

    public async void SearchCars()
    {
        try
        {
            cars = await apiclient.GetCarsForPurchaseAsync(filtroColor, modelo);
            errors = "";

            Console.WriteLine(cars.Count);

            if (cars.Count == 0 && !string.IsNullOrEmpty(filtroColor) && !string.IsNullOrEmpty(modelo))
            {
                errors = $"Error! There are not cars of color '{filtroColor}' and model '{modelo}'. Please apply other filters.";
            }
            else if (cars.Count == 0 && !string.IsNullOrEmpty(filtroColor))
            {
                errors = $"Error! There are not cars of color '{filtroColor}'. Please apply other filters.";
            }
            else if (cars.Count == 0 && !string.IsNullOrEmpty(modelo))
            {
                errors = $"Error! There are not cars of model '{modelo}'. Please apply other filters";
            }

        }
        catch (ApiException ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "Error while connecting the system";
        }
        StateHasChanged();
    }

    protected override Task OnInitializedAsync()
    {
        SearchCars();

        return base.OnInitializedAsync();
    }

    private void PurchaseCars()
    {
        navigation.NavigateTo("/purchase/post"); //lo referencia a el mismo esto luego se cambiará cuando se cree la página del post
    }
}