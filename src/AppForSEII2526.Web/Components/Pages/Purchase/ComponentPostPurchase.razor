@page "/purchase/post"

@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject AppForSEII2526APIClient apiclient
@inject ILogger<ComponentPostPurchase> logger
@inject PurchaseStateContainer purchaseState

@attribute [Authorize]

<h3>Create Purchase</h3>

<EditForm Model="purchase" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>
    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.Name" class="form-control" id="Nombre" />
                <label for="Name">Name </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.Surname" class="form-control" id="Apellidos" />
                <label for="Name">Surname </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.DeliveryCarDealer" class="form-control" id="DeliveryAddress" />
                <label for="DeliveryAddress">DeliveryCarDealer</label>
            </div>
        </div>
    </div>
    <div class="row g-2">
        <div class="col-md">
            <div class="form-floating">
                @*a dropdown for selecting the payment method*@
                <InputSelect class="form-select" @bind-Value="@purchase.PaymentMethod" id="PaymentMethod">
                    <option value="@PurchasePaymentMethodEnum.GooglePay" default> Google Pay</option>
                    <option value="@PurchasePaymentMethodEnum.Visa"> PayPal</option>
                </InputSelect>
                <label for="PaymentMethod">Payment Method</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating">
                @*this button will be used to ask the user if he want to proceed to purchase the cars*@
                <button class="btn btn-primary" type="submit" id="Submit" disabled="@purchaseButtonDisabled">
                    Purchase your cars
                </button>
            </div>
        </div>
    </div>
    <h4>Purchase Detail</h4>
    <p>
        <b>Precio total:</b> @TotalCost €
        <button class="btn btn-outline-primary" type="submit" @onclick="ModifyPurchaseItems" id="ModifyCars">
            Modify your cars
        </button>
    </p>
    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfPurchaseItems">
            <thead>
                <tr>
                    <th>Model</th>
                    <th>Color</th>
                    <th>Description</th>
                    <th>Purchasing Price</th>
                    <th>Quantity</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in purchase.PurchaseItems)
                {
                    <tr id="CarData_@item.Model">
                        <td>@item.Model</td>
                        <td>@item.Color</td>
                        <td>@item.Description</td>
                        <td>@item.PurchasingPrice</td>
                        <td><InputNumber @bind-Value="item.Quantity" class="form-control" id="@($"quantity_{item.Quantity}")" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@*a modal popup dialog for checking if user wants to proceed to purchase*@
@if (DialogIsOpen)
{
    <DialogPurchase Caption="Purchase cars"
    Message="¿Do you want to buy your selected cars?"
    OnClose="@OnDialogClose"
    Type=DialogPurchase.Category.SaveNot>   
    </DialogPurchase>
}

@code {
    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }
    private bool DialogIsOpen;
    private bool purchaseButtonDisabled
    {
        get { return (purchase.PurchaseItems == null || purchase.PurchaseItems.Count == 0); }
    }

    private decimal TotalCost
    {
        get
        {
            double price = purchase.PurchaseItems.Sum(ri => ri.PurchasingPrice * ri.Quantity);
            return Convert.ToDecimal(price);
        }
    }
    private void ModifyPurchaseItems()
    {
        navigation.NavigateTo("/purchase/select");
    }

    private PurchaseForCreateDTO purchase => purchaseState.Purchase;

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;
        if (isOk)
        {
            if (purchase.PurchaseItems.Count > 0)
            {
                try
                {
                    var purchased = await apiclient.CreatePurchaseAsync(purchase);
                    purchaseState.PurchaseProcessed();
                    navigation.NavigateTo($"/purchase/details?PurchaseID={purchased.Id}");
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {
                    if (apiexceptionvalidation.Result.Errors.Values != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                            //https://learn.microsoft.com/en-us/dotnet/api/system.string.join?view=net-7.0
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                    }
                }
                catch (ApiException apiexception)
                {
                    Console.WriteLine(apiexception.Message);
                    //we need to inform user that there was some other error while processing the request
                    messageError = "Error while processing your request, please try again later!";

                }
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {

        if (authenticationState is not null)
        {
            var authState = await authenticationState;
            var user = authState?.User;

            if (user is not null)
            {
                if (user.Identity is not null && user.Identity.IsAuthenticated)
                {
                    purchase.UserName = user.Identity.Name;
                }
            }
            purchase.Name = purchase.Name == null ? "" : purchase.Name;
            purchase.Surname = purchase.Surname == null ? "" : purchase.Surname;
            purchase.DeliveryCarDealer = purchase.DeliveryCarDealer == null ? "" : purchase.DeliveryCarDealer;
        }
    }

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }
}
